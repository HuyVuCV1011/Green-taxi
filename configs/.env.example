# Copy this file to ../.env before running Docker Compose from the repo root.
# Values are local development defaults only. Replace passwords in your own .env.

DATA_ROOT=./data
BUSINESS_TIMEZONE=America/New_York
AUDIT_TIMEZONE=UTC

# Driver HR source: service/hostname mysql_hr, container port 3306.
MYSQL_HR_HOST=127.0.0.1
MYSQL_HR_PORT=3307
MYSQL_HR_DATABASE=green_taxi_hr
MYSQL_HR_USER=green_taxi_hr_app
MYSQL_HR_PASSWORD=change_me_hr
MYSQL_HR_ROOT_PASSWORD=change_me_hr_root

# Fleet source: service/hostname mongodb_fleet, container port 27017.
MONGODB_FLEET_HOST=127.0.0.1
MONGODB_FLEET_PORT=27018
MONGODB_FLEET_DATABASE=green_taxi_fleet
MONGODB_FLEET_ROOT_USER=green_taxi_fleet_admin
MONGODB_FLEET_ROOT_PASSWORD=change_me_fleet_root

# Dispatch/Assignment source: service/hostname postgres_dispatch, container port 5432.
POSTGRES_DISPATCH_HOST=127.0.0.1
POSTGRES_DISPATCH_PORT=5433
POSTGRES_DISPATCH_DATABASE=green_taxi_dispatch
POSTGRES_DISPATCH_USER=green_taxi_dispatch_app
POSTGRES_DISPATCH_PASSWORD=change_me_dispatch

# Warehouse target placeholder: service/hostname postgres_warehouse, container port 5432.
POSTGRES_WAREHOUSE_HOST=127.0.0.1
POSTGRES_WAREHOUSE_PORT=5434
POSTGRES_WAREHOUSE_DATABASE=green_taxi_warehouse
POSTGRES_WAREHOUSE_USER=green_taxi_warehouse_app
POSTGRES_WAREHOUSE_PASSWORD=change_me_warehouse

# Backward-compatible generic warehouse aliases for scripts that expect DB_*.
DB_HOST=${POSTGRES_WAREHOUSE_HOST}
DB_PORT=${POSTGRES_WAREHOUSE_PORT}
DB_NAME=${POSTGRES_WAREHOUSE_DATABASE}
DB_USER=${POSTGRES_WAREHOUSE_USER}
DB_PASSWORD=${POSTGRES_WAREHOUSE_PASSWORD}
